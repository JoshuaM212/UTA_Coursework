// RGB LED Library
// Jason Losh

//-----------------------------------------------------------------------------
// Hardware Target
//-----------------------------------------------------------------------------

// Target Platform: EK-TM4C123GXL with LCD Interface
// Target uC:       TM4C123GH6PM
// System Clock:    40 MHz

// Hardware configuration:
// Red Backlight LED:
//   M1PWM5 (PF1) drives an NPN transistor that powers the red LED
// Green Backlight LED:
//   M1PWM7 (PF3) drives an NPN transistor that powers the green LED
// Blue Backlight LED:
//   M1PWM6 (PF2) drives an NPN transistor that powers the blue LED

//-----------------------------------------------------------------------------
// Device includes, defines, and assembler directives
//-----------------------------------------------------------------------------

#include <motor_control.h>
#include <stdint.h>
#include "tm4c123gh6pm.h"

#define SLEEP_SWITCH    (*((volatile uint32_t *)(0x42000000 + (0x400073FC-0x40000000)*32 + 7*4)))

// PortC masks
#define LEFT_FORWARD_MASK 32     //  PC5
#define LEFT_REVERSE_MASK 16     //  PC4

// PortF masks
#define RIGHT_FORWARD_MASK 128  // PA7
#define RIGHT_REVERSE_MASK 64   // PA6

// PortD mask

#define SLEEP_MASK 128   // PD7

//-----------------------------------------------------------------------------
// Global variables
//-----------------------------------------------------------------------------

//-----------------------------------------------------------------------------
// Subroutines
//-----------------------------------------------------------------------------

// Initialize RGB
void initPwm()
{
    // Enable clocks
    SYSCTL_RCGCPWM_R |= SYSCTL_RCGCPWM_R1 | SYSCTL_RCGCPWM_R0;         // Turns on PWM mod. 1 & 0
    SYSCTL_RCGCGPIO_R |= SYSCTL_RCGCGPIO_R3 | SYSCTL_RCGCGPIO_R2 | SYSCTL_RCGCGPIO_R0; // Ports D, C, A
    _delay_cycles(3);

    //Configure Motor Pins
    GPIO_PORTA_DIR_R |= RIGHT_FORWARD_MASK | RIGHT_REVERSE_MASK;
    GPIO_PORTA_DEN_R |= RIGHT_FORWARD_MASK | RIGHT_REVERSE_MASK;
    GPIO_PORTA_AFSEL_R |= RIGHT_FORWARD_MASK | RIGHT_REVERSE_MASK;
    GPIO_PORTA_PCTL_R &= ~(GPIO_PCTL_PA6_M | GPIO_PCTL_PA7_M);
    GPIO_PORTA_PCTL_R |= GPIO_PCTL_PA6_M1PWM2 | GPIO_PCTL_PA7_M1PWM3;

    GPIO_PORTC_DIR_R |= LEFT_FORWARD_MASK | LEFT_REVERSE_MASK;
    GPIO_PORTC_DEN_R |= LEFT_FORWARD_MASK | LEFT_REVERSE_MASK;
    GPIO_PORTC_AFSEL_R |= LEFT_FORWARD_MASK | LEFT_REVERSE_MASK;
    GPIO_PORTC_PCTL_R &= ~(GPIO_PCTL_PC4_M | GPIO_PCTL_PC5_M);
    GPIO_PORTC_PCTL_R |= GPIO_PCTL_PC4_M0PWM6 | GPIO_PCTL_PC5_M0PWM7;


    GPIO_PORTD_DIR_R |= SLEEP_MASK;
    GPIO_PORTD_DEN_R |= SLEEP_MASK;

    SLEEP_SWITCH = 1;


    // Configure PWM module 1 to drive RGB LED
    SYSCTL_SRPWM_R = SYSCTL_SRPWM_R1 | SYSCTL_SRPWM_R0;  // reset PWM1 module
    SYSCTL_SRPWM_R = 0;                              // leave reset state
    PWM1_1_CTL_R = 0;                                // turn-off PWM1 generator 1 (drives outs 2 and 3)

    PWM1_1_GENA_R = PWM_1_GENA_ACTCMPAD_ONE | PWM_1_GENA_ACTLOAD_ZERO;
                                                     // output 2 on PWM1, gen 1a, cmpa
    PWM1_1_GENB_R = PWM_1_GENB_ACTCMPBD_ONE | PWM_1_GENB_ACTLOAD_ZERO;
                                                     // output 3 on PWM1, gen 1b, cmpb

                                                     // set frequency to 40 MHz sys clock / 2 / 1024 = 19.53125 kHz
    PWM1_1_LOAD_R = 1024;                            // (internal counter counts down from load value to zero)

    PWM1_1_CMPB_R = 0;                               // set off
    PWM1_1_CMPA_R = 0;                               // set off

    PWM1_1_CTL_R = PWM_1_CTL_ENABLE;                 // turn-on PWM1 generator 1
    PWM1_ENABLE_R = PWM_ENABLE_PWM2EN | PWM_ENABLE_PWM3EN;
                                                     // enable outputs

    // Configure PWM module 0 to drive RGB LED
   // SYSCTL_SRPWM_R = SYSCTL_SRPWM_R0;                // reset PWM0 module
   // SYSCTL_SRPWM_R = 0;                              // leave reset state
    PWM0_3_CTL_R = 0;                                // turn-off PWM0 generator 3 (drives outs 6 and 7)

    PWM0_3_GENA_R = PWM_0_GENA_ACTCMPAD_ONE | PWM_0_GENA_ACTLOAD_ZERO;
                                                     // output 6 on PWM0, gen 3a, cmpa
    PWM0_3_GENB_R = PWM_0_GENB_ACTCMPBD_ONE | PWM_0_GENB_ACTLOAD_ZERO;
                                                     // output 7 on PWM0, gen 3b, cmpb

                                                     // set frequency to 40 MHz sys clock / 2 / 1024 = 19.53125 kHz
    PWM0_3_LOAD_R = 1024;                            // (internal counter counts down from load value to zero)

                                                     // red off (0=always low, 1023=always high)
    PWM0_3_CMPB_R = 0;                               // green off
    PWM0_3_CMPA_R = 0;                               // blue off

    PWM0_3_CTL_R = PWM_0_CTL_ENABLE;                 // turn-on PWM1 generator 3
    PWM0_ENABLE_R = PWM_ENABLE_PWM6EN | PWM_ENABLE_PWM7EN;
                                                     // enable outputs

}

void setPwm(uint16_t left_forward, uint16_t left_reverse, uint16_t right_forward, uint16_t right_reverse)
{
    PWM1_1_CMPA_R = left_forward;
    PWM1_1_CMPB_R = left_reverse;
    PWM0_3_CMPA_R = right_reverse;
    PWM0_3_CMPB_R = right_forward;
}

